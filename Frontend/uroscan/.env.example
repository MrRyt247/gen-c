# Supabase — get these from your project dashboard → Project Settings → API.
# Leave blank to run Uroscan in DEMO MODE (seeded mock data, no backend required).
PUBLIC_SUPABASE_URL=
PUBLIC_SUPABASE_ANON_KEY=

# Server-only secrets (never exposed to the browser).
SUPABASE_SERVICE_ROLE_KEY=
OPENAI_API_KEY=

# Roboflow hosted model that locates the reagent pads on a strip (server-only).
ROBOFLOW_API_KEY=
ROBOFLOW_MODEL=urine-test-strips-main/24
